function MENU_1() -- LOAD COUPON
    local savedList = gg.getListItems()
    local updateList = {}
    local prompt = gg.prompt({"Masukan nilai LOAD COUPON (Maks 1000):"}, {0}, {"number"})
    if not prompt then return end
    local inputUser = tonumber(prompt[1])
    if inputUser > 1000 then gg.alert("⚠️ Nilai tidak boleh lebih dari 1000!") return end
    if #savedList == 0 then gg.toast("Saved List kosong!") return end

    for _, item in ipairs(savedList) do
        local name = item.name or ""
        if name == "HANZ DATA 1" then item.value = "756F432Ch" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 2" then item.value = "4C6E6F70h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 3" then item.value = "5464616Fh" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 4" then item.value = "6E696172h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 5" then item.value = "70726941h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 6" then item.value = "0074726Fh" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ NILAI POINTER" then item.value = "0" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ NILAI" then item.value = tostring(inputUser) item.freeze = true table.insert(updateList, item) end
    end
    gg.setValues(updateList)
    gg.addListItems(updateList)
    gg.toast("✅ LOAD COUPON BERHASIL")
end

