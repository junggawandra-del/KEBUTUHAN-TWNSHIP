        "1. LOAD COUPON",
        "2. DEALER COUPON",
        "3. EXPANSION COUPON",
        "4. BARN UPGRADE COUPON",
        "5. FACTORY UPGRADE COUPON",
        "6. TRAIN UPGRADE COUPON",
        "7. ISLAND UPGRADE COUPON",
        "❌ KELUAR"
    }, nil, "📅 " .. date .. " | 🕒 " .. time .. "\n━━━━━━━━━━━━━━━\nTOWNSHIP\nMENU COUPON 🎫")

    if menu == 1 then MENU_1() end
    if menu == 2 then MENU_2() end
    if menu == 3 then MENU_3() end
    if menu == 4 then MENU_4() end
    if menu == 5 then MENU_5() end
    if menu == 6 then MENU_6() end
    if menu == 7 then MENU_7() end
    if menu == 8 then os.exit() end
    X = -1
end

