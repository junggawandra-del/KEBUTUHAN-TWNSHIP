-- ==========================================
-- 1. LOGIKA KHUSUS TOPAZ
-- ==========================================
function HANZ_TOPAZ_LOGIC()
    local savedList = gg.getListItems()
    local updateList = {}

    local prompt = gg.prompt({"[TOPAZ] Masukan nilai (Maks 1000):"}, {0}, {"number"})
    if not prompt then return end
    local inputUser = tonumber(prompt[1])

    if inputUser > 1000 then
        gg.alert("⚠️ Nilai tidak boleh lebih dari 1000!")
        return
    end

    if #savedList == 0 then gg.toast("Saved List kosong!") return end

    for _, item in ipairs(savedList) do
        local name = item.name or ""
        -- Update Value Berdasarkan Hex Code Topaz
        if name == "HANZ DATA 1" then item.value = "6D656708h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 2" then item.value = "00000031h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 3" then item.value = "00000000h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 4" then item.value = "00000000h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 5" then item.value = "00000000h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 6" then item.value = "00000000h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ NILAI POINTER" then item.value = "0" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ NILAI" then item.value = tostring(inputUser) item.freeze = true table.insert(updateList, item) end
    end

    if #updateList > 0 then
        gg.setValues(updateList)
        gg.addListItems(updateList)
        gg.toast("✅ TOPAZ Berhasil!")
    else
        gg.toast("⚠️ Data tidak ditemukan.")
    end
end

