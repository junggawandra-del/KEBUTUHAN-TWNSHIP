-- ==========================================
-- TAMPILAN MENU UTAMA
-- ==========================================
function MAIN()
    gg.clearResults()
    
    local date = os.date("%A, %d %B %Y")
    local time = os.date("%X")
    
    local menu = gg.choice({
        "1. 💎 TOPAZ",
        "2. 💎 EMERALD",
        "3. 💎 RUBY",
        "❌ KELUAR"
    }, nil, 
    "━━━━━━━━━━━━━━━━━━━━━━\n" ..
    "📅 " .. date .. "\n" ..
    "⏰ " .. time .. "\n" ..
    "━━━━━━━━━━━━━━━━━━━━━━\n" ..
    "🎮 GAME : TOWNSHIP\n" ..
    "👤 DEV  : HANZ\n" ..
    "💎 MENU : GEMS/PERMATA\n" ..
    "━━━━━━━━━━━━━━━━━━━━━━")

    if menu == 1 then HANZ_TOPAZ_LOGIC() end
    if menu == 2 then HANZ_EMERALD_LOGIC() end
    if menu == 3 then HANZ_RUBY_LOGIC() end
    if menu == 4 then os.exit() end
    
    HANZ_AUTO = -1 
end

-- JALANKAN LOADING SEKALI SAAT START
HANZ_LOADING()

-- LOOP OTOMATIS
while true do
    if gg.isVisible(true) then
        HANZ_AUTO = 1
        gg.setVisible(false)
    end
    if HANZ_AUTO == 1 then
        MAIN()
    end
end

