-- 2. EFEK LOADING KEREN
function HANZ_LOADING()
    local frames = {"[ □ □ □ □ □ ]", "[ ■ □ □ □ □ ]", "[ ■ ■ □ □ □ ]", "[ ■ ■ ■ □ □ ]", "[ ■ ■ ■ ■ □ ]", "[ ■ ■ ■ ■ ■ ]"}
    for i = 1, 2 do
        for _, frame in ipairs(frames) do
            gg.toast("⚡ LOADING SYSTEM ⚡\n" .. frame)
            gg.sleep(100)
        end
    end
    gg.toast("✅ READY TO USE")
end

-- 3. FUNGSI LOGIKA TIAP MENU (KOMPLIT & TERPISAH)

function LOGIC_GLASS()
    local savedList = gg.getListItems()
    local updateList = {}
    local prompt = gg.prompt({"GLASS: Masukan nilai (Maks 1000):"}, {0}, {"number"})
    if not prompt then return end
    local inputUser = tonumber(prompt[1])
    if inputUser > 1000 then gg.alert("⚠️ [KESALAHAN]\nNilai tidak boleh lebih dari 1000!") return end
    if #savedList == 0 then gg.toast("Saved List kosong!") return end

    for _, item in ipairs(savedList) do
        local name = item.name or ""
        if name == "HANZ DATA 1" then item.value = "616C470Ah"
        elseif name == "HANZ DATA 2" then item.value = "00007373h"
        elseif name == "HANZ DATA 3" then item.value = "00000000h"
        elseif name == "HANZ DATA 4" then item.value = "00000000h"
        elseif name == "HANZ DATA 5" then item.value = "00000000h"
        elseif name == "HANZ DATA 6" then item.value = "00000000h"
        elseif name == "HANZ NILAI POINTER" then item.value = "0"
        elseif name == "HANZ NILAI" then item.value = tostring(inputUser) end
        if name:match("HANZ") then item.freeze = true table.insert(updateList, item) end
    end
    gg.setValues(updateList)
    gg.addListItems(updateList)
    gg.toast("✅ GLASS BERHASIL")
end

