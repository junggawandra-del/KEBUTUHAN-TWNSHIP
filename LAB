-- 1. FUNGSI LOADING KEREEN
function HANZ_LOADER()
    local logo = [[ LOADING... ]]
    
    local frames = {" ▬▬▬ ", " ▬▭▬ ", " ▬▬▬ ", " ▬▭▬ "}
    for i = 1, 4 do
        for _, frame in ipairs(frames) do
            gg.toast(logo .. "\n" .. frame .. " LOADING SYSTEM " .. frame)
            gg.sleep(150)
        end
    end
end

-- 2. FUNGSI HEADER (TANGGAL & JAM AKURAT)
function SHOW_HEADER()
    local tgl = os.date("%A, %d %B %Y")
    local jam = os.date("%H:%M:%S")
    return "📅 " .. tgl .. "\n⏰ " .. jam .. "\n\nGAME : TOWNSHIP\nDEV : HANZ\nMENU : LAB BOOSTER\n" .. string.rep("━", 22)
end

