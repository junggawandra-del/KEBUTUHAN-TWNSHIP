-- ==========================================
-- MENU UTAMA & OTOMATISASI
-- ==========================================
function MAIN_MENU()
    local date = os.date("%A, %d %B %Y")
    local time = os.date("%H:%M:%S")
    
    local menu = gg.choice({
        "1. BRONZE INGOTS",
        "2. SILVER INGOTS",
        "3. GOLD INGOTS",
        "4. PLATINUM INGOTS",
        "❌ KELUAR"
    }, nil, 
    "📅 " .. date .. "\n⏰ " .. time .. 
    "\n━━━━━━━━━━━━━━━\n🎮 GAME : TOWNSHIP\n👤 DEV : HANZ\n💎 MENU : BATANGAN/INGOTS\n━━━━━━━━━━━━━━━")

    if menu == 1 then BRONZE_LOGIC() end
    if menu == 2 then SILVER_LOGIC() end
    if menu == 3 then GOLD_LOGIC() end
    if menu == 4 then PLATINUM_LOGIC() end
    if menu == 5 then os.exit() end
    
    HANZ_STATUS = -1
end

LOADING_EFFECT()

-- Loop agar otomatis tampil saat ikon GG diklik
while true do
    if gg.isVisible(true) then
        HANZ_STATUS = 1
        gg.setVisible(false)
    end
    if HANZ_STATUS == 1 then
        MAIN_MENU()
    end
end
