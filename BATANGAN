-- Efek Loading Keren
function LOADING_EFFECT()
    local frames = {"▓▒░░░░░", "▓▓▒░░░░", "▓▓▓▒░░░", "▓▓▓▓▒░░", "▓▓▓▓▓▒░", "▓▓▓▓▓▓▒", "▓▓▓▓▓▓▓"}
    for i = 1, #frames do
        gg.toast("• [HANZ LOADER] •\n" .. frames[i] .. " Loading...")
        gg.sleep(200)
    end
end

-- ==========================================
-- MENU 1: BRONZE INGOTS
-- ==========================================
function BRONZE_LOGIC()
    local savedList = gg.getListItems()
    local updateList = {}
    local prompt = gg.prompt({"[BRONZE] Masukan nilai (Maks 1000):"}, {0}, {"number"})
    if not prompt then return end
    local inputUser = tonumber(prompt[1])
    if inputUser > 1000 then gg.alert("Maksimal 1000!"); return end
    if #savedList == 0 then gg.toast("Saved List kosong!"); return end

    for _, item in ipairs(savedList) do
        local name = item.name or ""
        if name == "HANZ DATA 1" then item.value = "6F724228h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 2" then item.value = "42657A6Eh" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 3" then item.value = "696C6C75h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 4" then item.value = "6F436E6Fh" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 5" then item.value = "65746E75h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ DATA 6" then item.value = "00000072h" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ NILAI POINTER" then item.value = "0" item.freeze = true table.insert(updateList, item) end
        if name == "HANZ NILAI" then item.value = tostring(inputUser) item.freeze = true table.insert(updateList, item) end
    end
    if #updateList > 0 then gg.setValues(updateList) gg.addListItems(updateList) gg.toast("✅ Bronze Berhasil!") end
end

