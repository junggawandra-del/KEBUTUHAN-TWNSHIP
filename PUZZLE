-- 1. ROCKET
function MENU_1()
    local prompt = gg.prompt({"🚀 ROCKET: Masukan nilai (Maks 1000):"}, {0}, {"number"})
    if not prompt then return end
    local val = tonumber(prompt[1])
    if val > 1000 then gg.alert("⚠️ Maksimal 1000!"); return end

    local sl = gg.getListItems()
    local up = {}
    for _, item in ipairs(sl) do
        local name = item.name or ""
        if name == "HANZ DATA 1" then item.value = "4C336D0Ch"; item.freeze = true; table.insert(up, item) end
        if name == "HANZ DATA 2" then item.value = "00656E69h"; item.freeze = true; table.insert(up, item) end
        if name == "HANZ DATA 3" then item.value = "00000000h"; item.freeze = true; table.insert(up, item) end
        if name == "HANZ DATA 4" then item.value = "00000000h"; item.freeze = true; table.insert(up, item) end
        if name == "HANZ DATA 5" then item.value = "00000000h"; item.freeze = true; table.insert(up, item) end
        if name == "HANZ DATA 6" then item.value = "00000000h"; item.freeze = true; table.insert(up, item) end
        if name == "HANZ NILAI POINTER" then item.value = "0"; item.freeze = true; table.insert(up, item) end
        if name == "HANZ NILAI" then item.value = tostring(val); item.freeze = true; table.insert(up, item) end
    end
    gg.setValues(up); gg.addListItems(up); gg.toast("✅ ROCKET DONE")
end

