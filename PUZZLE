function MAIN_INTERFACE()
    local date = os.date("📅 %A, %d %B %Y")
    local time = os.date("🕒 %H:%M:%S")
    
    local menu = gg.choice({
        "🚀 1. ROCKET",
        "🧨 2. DYNAMITE",
        "🌈 3. RAINBOW BALL",
        "🚰 4. HYDRANT",
        "🧤 5. GLOVE",
        "❤️ 6. UNLIMITED LIVES",
        "💎 7. DRILL",
        "⚖️ 8. WEIGHT",
        "🌀 9. FAN",
        "🔨 10. JACKHAMMER",
        "⭐ 11. MULTIPLIER X2",
        "❌ KELUAR / EXIT"
    }, nil, "━━━━━━━━━━━━━━━━━━━━━━\n" .. 
           date .. "\n" .. 
           time .. "\n" ..
           "━━━━━━━━━━━━━━━━━━━━━━\n" ..
           "🎮 GAME : TOWNSHIP\n" ..
           "👤 DEV  : HANZ\n" ..
           "🧩 MENU : PUZZLE ITEM\n" ..
           "━━━━━━━━━━━━━━━━━━━━━━")

    if menu == 1 then MENU_1() end
    if menu == 2 then MENU_2() end
    if menu == 3 then MENU_3() end
    if menu == 4 then MENU_4() end
    if menu == 5 then MENU_5() end
    if menu == 6 then MENU_6() end
    if menu == 7 then MENU_7() end
    if menu == 8 then MENU_8() end
    if menu == 9 then MENU_9() end
    if menu == 10 then MENU_10() end
    if menu == 11 then MENU_11() end
    if menu == 12 then os.exit() end
    
    HANZ_STATE = -1
end

