function LOADING_SCREEN()
    local frames = {"▖", "▘", "▝", "▗"}
    for i = 1, 15 do
        gg.toast("⏳ LOADING DATA " .. frames[(i % #frames) + 1] .. " [ " .. (i * 7) .. "% ]")
        gg.sleep(120)
    end
    gg.toast("✅ READY TO USE")
end

